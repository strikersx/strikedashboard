{
  "name": "strikehousedashboard",
  "version": "1.0.0",
  "description": "Striker's House operational control dashboard",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "phone:spike": "RUN_SPIKES=1 vitest run tests/spike/phone-normalisation.test.ts --reporter=verbose",
    "postinstall": "prisma generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
