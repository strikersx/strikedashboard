# Database — Prisma 7 uses the libsql adapter for both local sqlite and Turso.
#   Local dev: DATABASE_URL=file:./dev.db  (auth token unused)
#   Prod (Turso): DATABASE_URL=libsql://…  + DATABASE_AUTH_TOKEN=…
# Turso vars are auto-provisioned by the Vercel Marketplace Turso integration.
DATABASE_URL="file:./dev.db"
