# Auth
ADMIN_PWD=carcavelos2026
SALES_PWD=leads2026

# Yogo API
YOGO_TOKEN=your-yogo-jwt-token
YOGO_BASE=https://api.yogo.dk
YOGO_ORIGIN=https://strikershouse.yogobooking.pt

# Database — Prisma 7 uses the libsql adapter for both local sqlite and Turso.
#   Local dev: DATABASE_URL=file:./dev.db  (auth token unused)
#   Prod (Turso): DATABASE_URL=libsql://…  + DATABASE_AUTH_TOKEN=…
# Turso vars are auto-provisioned by the Vercel Marketplace Turso integration.
DATABASE_URL="file:./dev.db"
# DATABASE_AUTH_TOKEN=

# WhatsApp Cloud API
WA_PHONE_NUMBER_ID=
WA_BUSINESS_ACCOUNT_ID=
WA_ACCESS_TOKEN=
WA_APP_SECRET=
WA_VERIFY_TOKEN=
# Admin phone in E.164 (e.g. +351912873698) — receiver of OOB notifications
# from /api/whatsapp/admin/group-invite/bulk and other admin actions.
RICARDO_PHONE_E164=
WA_TEMPLATE_TRIAL_FOLLOWUP=trial_followup_pt
# WhatsApp group invite link, regenerated from the WhatsApp app's
# "Invite via link → Copy" option. Used by /api/whatsapp/admin/group-invite/bulk.
WA_GROUP_INVITE_URL=
# Kill switch — set to false to ack-only without dispatch
WA_ENABLED=true
# Per-flow opt-in flags (must be literal "true").
WA_FLOW_RESERVAR=false

# Cron — Bearer token guarding /api/cron/*  (Slice 5+)
CRON_SECRET=

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/auth/callback
SPOTIFY_TOKEN_ENCRYPTION_KEY=        # 32 bytes base64 (openssl rand -base64 32)
SPOTIFY_BASE_PLAYLIST_ID=
